rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null &&
        (request.auth.token.admin == true ||
         request.auth.uid == "5efzvBMxHXOBkQMU8VcVLXBX8QS2");
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isOrderOwner(orderId) {
      return (
        exists(/databases/$(database)/documents/orders/$(orderId)) &&
        (
          get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/orders/$(orderId)).data.user_id == request.auth.uid
        )
      ) || (
        exists(/databases/$(database)/documents/encomendas/$(orderId)) &&
        (
          get(/databases/$(database)/documents/encomendas/$(orderId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/encomendas/$(orderId)).data.user_id == request.auth.uid
        )
      );
    }

    function canAccessConversation(conversationId) {
      return isAdmin() ||
        (
          exists(/databases/$(database)/documents/chat_conversations/$(conversationId)) &&
          (
            get(/databases/$(database)/documents/chat_conversations/$(conversationId)).data.customer_id == request.auth.uid ||
            get(/databases/$(database)/documents/chat_conversations/$(conversationId)).data.customerId == request.auth.uid
          )
        ) ||
        (
          exists(/databases/$(database)/documents/conversas_chat/$(conversationId)) &&
          (
            get(/databases/$(database)/documents/conversas_chat/$(conversationId)).data.customer_id == request.auth.uid ||
            get(/databases/$(database)/documents/conversas_chat/$(conversationId)).data.customerId == request.auth.uid
          )
        );
    }

    match /produtos/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /products/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /categorias/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /categories/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /encomendas/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || resource.data.user_id == request.auth.uid || isAdmin());

      allow create: if isAuthenticated() &&
        (request.resource.data.userId == request.auth.uid || request.resource.data.user_id == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    match /orders/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || resource.data.user_id == request.auth.uid || isAdmin());

      allow create: if isAuthenticated() &&
        (request.resource.data.userId == request.auth.uid || request.resource.data.user_id == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    match /order_items/{id} {
      allow read: if isAuthenticated() &&
        (isAdmin() || isOrderOwner(resource.data.order_id));
      allow create: if isAuthenticated() &&
        (isAdmin() || isOrderOwner(request.resource.data.order_id));
      allow update, delete: if isAdmin();
    }

    match /itens_encomenda/{id} {
      allow read: if isAuthenticated() &&
        (isAdmin() || isOrderOwner(resource.data.order_id));
      allow create: if isAuthenticated() &&
        (isAdmin() || isOrderOwner(request.resource.data.order_id));
      allow update, delete: if isAdmin();
    }

    match /profiles/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isAuthenticated() &&
        (request.resource.data.user_id == request.auth.uid || request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /perfis/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isAuthenticated() &&
        (request.resource.data.user_id == request.auth.uid || request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /carrinhos/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /reviews/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /anuncios/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ads/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /novidades/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /site_settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /definicoes_site/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /seasonal_themes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /temas_sazonais/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /newsletter_subscribers/{id} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /subscritores_newsletter/{id} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /chat_conversations/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.customer_id == request.auth.uid || resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        (request.resource.data.customer_id == request.auth.uid || request.resource.data.customerId == request.auth.uid || isAdmin());
      allow update, delete: if isAuthenticated() &&
        (resource.data.customer_id == request.auth.uid || resource.data.customerId == request.auth.uid || isAdmin());
    }

    match /conversas_chat/{id} {
      allow read: if isAuthenticated() &&
        (resource.data.customer_id == request.auth.uid || resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        (request.resource.data.customer_id == request.auth.uid || request.resource.data.customerId == request.auth.uid || isAdmin());
      allow update, delete: if isAuthenticated() &&
        (resource.data.customer_id == request.auth.uid || resource.data.customerId == request.auth.uid || isAdmin());
    }

    match /chat_messages/{id} {
      allow read: if isAuthenticated() &&
        canAccessConversation(resource.data.conversation_id);
      allow create: if isAuthenticated() &&
        canAccessConversation(request.resource.data.conversation_id);
      allow update, delete: if isAuthenticated() &&
        (isAdmin() || resource.data.sender_id == request.auth.uid);
    }

    match /mensagens_chat/{id} {
      allow read: if isAuthenticated() &&
        canAccessConversation(resource.data.conversation_id);
      allow create: if isAuthenticated() &&
        canAccessConversation(request.resource.data.conversation_id);
      allow update, delete: if isAuthenticated() &&
        (isAdmin() || resource.data.sender_id == request.auth.uid);
    }

    match /chats/{chatId} {
      allow read, write: if isAuthenticated();
    }

    // Compatibility collection for simpler chat implementations.
    match /chatMessages/{id} {
      allow read, create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        (isAdmin() || resource.data.userId == request.auth.uid || resource.data.user_id == request.auth.uid);
    }
  }
}
