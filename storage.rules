rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null &&
        (request.auth.token.admin == true ||
         request.auth.uid == "5efzvBMxHXOBkQMU8VcVLXBX8QS2");
    }

    match /{allPaths=**} {
      allow read: if !allPaths.matches('chat-images/.*') || isAuthenticated();
      allow write: if !allPaths.matches('chat-images/.*') && isAdmin();
    }

    match /chat-images/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
