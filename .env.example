# ============================================
# Fio & Alma Studio - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# ============================================

# ---- Frontend (VITE_ prefix = exposed to browser) ----
# These are safe to expose — they are public/anon keys governed by RLS.
VITE_SITE_URL=https://your-domain.com

# ---- Firebase (new auth + firestore) ----
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_ADMIN_UID=5efzvBMxHXOBkQMU8VcVLXBX8QS2

# ---- Supabase legacy (keep only while migrating remaining modules) ----
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
# Optional alias supported in this project:
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---- Backend-only (Supabase Edge Functions) ----
# These are set as Supabase secrets (supabase secrets set KEY=value)
# and are NEVER exposed to the browser.
#
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# RESEND_API_KEY=your-resend-api-key
# RESEND_FROM_EMAIL=noreply@yourdomain.com
# SITE_URL=https://yourdomain.com
